# ─────────────────────────────────────────────
# Space-Rover-AI Backend Environment Variables
# Copy this file to backend/.env and fill in values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# OpenAI API Key (required for AI-powered endpoints)
OPENAI_API_KEY=sk-your-openai-api-key-here

# FastAPI Application Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# CORS Origins (comma-separated, no spaces)
CORS_ORIGINS=https://main.d3ff6psmre7r2a.amplifyapp.com

# Model Configuration
MODEL_PATH=../ml_model/model.pkl

# Logging
LOG_LEVEL=INFO
